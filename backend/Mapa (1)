estados = ['Aguascalientes', 'Baja California', 'Baja California Sur', 'Campeche', 'Chiapas', 'Chihuahua',
           'Ciudad de México', 'Coahuila', 'Colima', 'Durango', 'Guanajuato', 'Guerrero', 'Hidalgo', 'Jalisco',
           'México', 'Michoacán', 'Morelos', 'Nayarit', 'Nuevo León', 'Oaxaca', 'Puebla', 'Querétaro',
           'Quintana Roo', 'San Luis Potosí', 'Sinaloa', 'Sonora', 'Tabasco', 'Tamaulipas', 'Tlaxcala',
           'Veracruz', 'Yucatán', 'Zacatecas']

data = {
    'Nombre del estado': np.random.choice(estados, size=100),
    'Cantidad de crímenes': np.random.randint(50, 500, size=100),
    'Latitude': np.random.uniform(14, 32, size=100),
    'Longitude': np.random.uniform(-120, -80, size=100),
}

df = pd.DataFrame(data)

app = generate_dash_app(df, 'Nombre del estado', 'Cantidad de crímenes', 'Crímenes por Estado', 'Estado', 'Cantidad de Crímenes')

if __name__ == '__main__':
    app.run_server(debug=True)

