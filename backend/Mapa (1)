import dash
from dash import dcc, html
from dash.dependencies import Input, Output
import pandas as pd
import numpy as np
import dash_leaflet as dl

def generate_dash_app(data, state_column, value_column, title, xaxis_title, yaxis_title):
    app = dash.Dash(__name__)

    app.layout = html.Div(
        children=[
            html.H1(title),
            dcc.Dropdown(
                id='state-selector',
                options=[{'label': state, 'value': state} for state in data[state_column].unique()],
                value=[data[state_column].unique()[0]],  # Set a default state, now as a list
                multi=True  # Allow multiple state selection
            ),
            dl.Map(id="map", style={'width': '100%', 'height': '50vh'}, center=[23.6345, -102.5528], zoom=5, children=[
                dl.TileLayer(id="base-layer-id"),
                dl.LayerGroup(id="layer-group-id"),
            ]),
            dcc.Graph(
                id='my-graph',
                # Add your own attributes and configurations here
            ),
            # Add other components as needed
        ]
    )

    @app.callback(
        [Output('my-graph', 'figure'),
         Output("layer-group-id", "children")],
        [Input('state-selector', 'value')]
    )
    def update_graph(selected_states):
        if isinstance(selected_states, str):
            selected_states = [selected_states]

        # Filter the DataFrame to include only the selected states
        filtered_df = data[data[state_column].isin(selected_states)]

        # Logic to update the graph based on the selected states
        # Add your specific logic for your application and graph

        # For example, create a bar chart with the quantity of crimes per state
        fig = {
            'data': [
                {'x': filtered_df[state_column], 'y': filtered_df[value_column], 'type': 'bar', 'name': value_column},
            ],
            'layout': {
                'title': title,
                'xaxis': {'title': xaxis_title},
                'yaxis': {'title': yaxis_title},
            }
        }

        # Create map markers based on the selected states
        markers = [
            dl.Marker(
                position=[df[df[state_column] == state]['Latitude'].iloc[0],
                          df[df[state_column] == state]['Longitude'].iloc[0]],
                children=[
                    dl.Popup(df[df[state_column] == state][value_column].iloc[0])
                ]
            ) for state in selected_states
        ]

        return fig, markers

    return app


